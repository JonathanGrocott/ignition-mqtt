# Module signing configuration
# Copy this file to gradle.properties and fill in your values
# DO NOT commit gradle.properties to git (it contains passwords)

ignition.signing.keystoreFile=certs/module-keystore.jks
ignition.signing.keystorePassword=YOUR_KEYSTORE_PASSWORD
ignition.signing.certAlias=module-signer
ignition.signing.certPassword=YOUR_CERT_PASSWORD
ignition.signing.certFile=certs/module-cert.pem
