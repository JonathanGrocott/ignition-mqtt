{
  "broker": {
    "brokerUrl": "tcp://localhost:1883",
    "clientId": "ignition-mqtt-publisher",
    "username": "",
    "password": "",
    "qos": 1,
    "retained": false,
    "cleanSession": true,
    "connectionTimeout": 30,
    "keepAlive": 60
  },
  "tags": {
    "enabled": true,
    "tagProviders": [
      "default"
    ],
    "tagFolders": [
      "[default]TestTags",
      "[default]Production/Line1"
    ],
    "valueDeadband": 0.1,
    "publishOnQualityChange": true,
    "includeMetadata": true,
    "topicOverrides": {
      "[default]TestTags/Temperature": "factory/zone1/temp",
      "[default]TestTags/Pressure": "factory/zone1/pressure"
    }
  }
}
